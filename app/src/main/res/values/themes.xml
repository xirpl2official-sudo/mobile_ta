<resources xmlns:tools="http://schemas.android.com/tools">
    
    <style name="Base.Theme.SAS_Mobile" parent="Theme.Material3.DayNight.NoActionBar">
        
        <item name="colorPrimary">@color/black</item>
        <item name="colorControlActivated">@color/black</item>
        <item name="colorControlHighlight">@color/black</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowAnimationStyle">@style/Animation.NoAnimation</item>

        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/outline</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/on_background</item>
        <item name="colorSurfaceContainerLow">@color/surface</item>
        <item name="colorSurfaceContainer">@color/surface_container</item>
        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline_variant</item>
        
    </style>

    <style name="Theme.SAS_Mobile" parent="Base.Theme.SAS_Mobile" />

    <style name="Theme.SAS_Mobile.WhiteBackground" parent="Theme.SAS_Mobile">
        <item name="colorControlActivated">@color/black</item>
    </style>

    <style name="Animation.NoAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@null</item>
        <item name="android:activityOpenExitAnimation">@null</item>
        <item name="android:activityCloseEnterAnimation">@null</item>
        <item name="android:activityCloseExitAnimation">@null</item>
        <item name="android:windowEnterAnimation">@null</item>
        <item name="android:windowExitAnimation">@null</item>
    </style>

    <style name="TransparentDialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="CustomBottomSheetDialogTheme" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="BottomNavActive" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/blue_theme</item>
        <item name="android:height">32dp</item>
        <item name="android:width">64dp</item>
    </style>

    <style name="Widget.App.FormField" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="hintTextColor">@color/hint_and_floating</item>
        <item name="boxStrokeColor">@color/stroke_form_field</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="shapeAppearanceOverlay">@style/Widget.App.FormField.Shape</item>
    </style>

    <style name="Widget.App.FormField.Shape">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="Widget.App.FormField.Dropdown" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="hintTextColor">@color/hint_and_floating</item>
        <item name="boxStrokeColor">@color/stroke_form_field</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="shapeAppearanceOverlay">@style/Widget.App.FormField.Shape</item>
    </style>

    <!-- Material 3 Typography Scale -->
    <style name="TextAppearance.SAS.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">@font/poppins_bold</item>
    </style>
    <style name="TextAppearance.SAS.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="fontFamily">@font/poppins_bold</item>
    </style>
    <style name="TextAppearance.SAS.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/poppins_semibold</item>
    </style>
    <style name="TextAppearance.SAS.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/poppins_semibold</item>
    </style>
    <style name="TextAppearance.SAS.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/poppins_semibold</item>
    </style>
    <style name="TextAppearance.SAS.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/poppins_medium</item>
    </style>
    <style name="TextAppearance.SAS.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/poppins_medium</item>
    </style>
    <style name="TextAppearance.SAS.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">@font/poppins_medium</item>
    </style>
    <style name="TextAppearance.SAS.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/poppins_light</item>
    </style>
    <style name="TextAppearance.SAS.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/poppins_light</item>
    </style>
    <style name="TextAppearance.SAS.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/poppins_light</item>
    </style>
    <style name="TextAppearance.SAS.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/poppins_medium</item>
    </style>
    <style name="TextAppearance.SAS.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/poppins_medium</item>
    </style>
    <style name="TextAppearance.SAS.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">@font/poppins_medium</item>
    </style>
</resources>