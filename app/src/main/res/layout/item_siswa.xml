<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="8dp"
    android:background="@color/background">

    
    <CheckBox
        android:id="@+id/cbRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:layout_marginStart="8dp" />

    
    <TextView
        android:id="@+id/tvNis"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="8dp"
        android:textColor="@color/on_background"
        android:textSize="12sp" />

    
    <LinearLayout
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <TextView
            android:id="@+id/tvNama"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/on_background"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/ivDeviceStatus"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginStart="4dp"
            android:contentDescription="Status perangkat"
            android:src="@drawable/bg_circle_indicator"
            android:visibility="gone"
            app:tint="@color/gray"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

    </LinearLayout>

    
    <TextView
        android:id="@+id/tvJenisKelamin"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="4dp"
        android:textColor="@color/on_background"
        android:textSize="12sp" />

    
    <TextView
        android:id="@+id/tvKelas"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="4dp"
        android:textColor="@color/on_background"
        android:textSize="12sp" />

    
    <TextView
        android:id="@+id/tvJurusan"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:background="@drawable/bg_badge_jurusan"
        android:textColor="@color/blue_theme"
        android:textSize="11sp" />

    
    <TextView
        android:id="@+id/tvStatusAkademik"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:gravity="center"
        android:paddingHorizontal="6dp"
        android:paddingVertical="3dp"
        android:background="@drawable/bg_status_gray"
        android:textColor="@android:color/white"
        android:textSize="10sp"
        android:text="AKTIF" />

    
    <LinearLayout
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetailSiswa"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="Detail"
            android:textAllCaps="false"
            android:textSize="10sp"
            android:textColor="@android:color/white"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="6dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />
    </LinearLayout>

    
    <LinearLayout
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="8dp">

        <ImageView
            android:id="@+id/btnEdit"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_edit"
            android:contentDescription="Edit"
            app:tint="@color/blue_theme"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete"
            android:contentDescription="Delete"
            app:tint="#F44336"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

    </LinearLayout>

</LinearLayout>
