<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".TambahSiswaActivity">

    <!-- Top AppBar - Custom Blue Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBarContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="90dp"
        android:background="@color/blue_theme"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/iconBackContainer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/iconBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back"
                android:contentDescription="Kembali"
                app:tint="@android:color/white" />
        </FrameLayout>

        <ImageView
            android:id="@+id/logoSekolah"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/logo_smk"
            android:contentDescription="Logo SMKN 2"
            app:layout_constraintStart_toEndOf="@id/iconBackContainer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tvPageTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tambah Siswa"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/logoSekolah"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/textNamaSekolah"
            app:layout_constraintVertical_chainStyle="packed"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/textNamaSekolah"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="SMK Negeri 2 Singosari"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintStart_toStartOf="@id/tvPageTitle"
            app:layout_constraintTop_toBottomOf="@id/tvPageTitle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="8dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBarContent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Form Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/surface"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/slate_50"
                        android:padding="16dp"
                        android:text="DATA SISWA BARU"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/outline_variant" />

                    <!-- Form Fields -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <!-- NIS -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.App.FormField"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="NIS"
                            android:layout_marginBottom="16dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNisSiswa"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- NAMA SISWA -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.App.FormField"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Nama Siswa"
                            android:layout_marginBottom="16dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNamaSiswa"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName|textCapWords"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Jurusan & Kelas (side by side) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.App.FormField.Dropdown"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Konsentrasi Keahlian"
                                android:layout_marginEnd="8dp">

                                <AutoCompleteTextView
                                    android:id="@+id/actvJurusan"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="none"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.App.FormField.Dropdown"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Kelas"
                                android:layout_marginStart="8dp">

                                <AutoCompleteTextView
                                    android:id="@+id/actvKelas"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="none"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <!-- Tahun Masuk & Jenis Kelamin (side by side) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.App.FormField.Dropdown"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Tahun Masuk"
                                android:layout_marginEnd="8dp">

                                <AutoCompleteTextView
                                    android:id="@+id/actvTahunMasuk"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="none"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Jenis Kelamin"
                                    android:textColor="@color/slate_700"
                                    android:textSize="12sp"
                                    android:layout_marginBottom="4dp" />

                                <RadioGroup
                                    android:id="@+id/rgJenisKelamin"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <RadioButton
                                        android:id="@+id/rbLakiLaki"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginEnd="6dp"
                                        android:background="@drawable/bg_radio_card_selector"
                                        android:button="@null"
                                        android:checked="true"
                                        android:gravity="center"
                                        android:paddingVertical="12dp"
                                        android:text="Laki-Laki"
                                        android:textColor="@color/slate_700"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:contentDescription="Laki-laki" />

                                    <RadioButton
                                        android:id="@+id/rbPerempuan"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginStart="6dp"
                                        android:background="@drawable/bg_radio_card_selector"
                                        android:button="@null"
                                        android:gravity="center"
                                        android:paddingVertical="12dp"
                                        android:text="Perempuan"
                                        android:textColor="@color/slate_700"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:contentDescription="Perempuan" />
                                </RadioGroup>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Agama -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.App.FormField.Dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Agama"
                            android:layout_marginBottom="24dp">

                            <AutoCompleteTextView
                                android:id="@+id/actvAgama"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- KIRIM Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnKirim"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"
                            android:backgroundTint="@color/primary"
                            android:text="Simpan"
                            android:textColor="@color/on_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:cornerRadius="8dp"
                            app:icon="@drawable/ic_send"
                            app:iconGravity="textStart" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Full Screen Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#80FFFFFF"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            app:indicatorColor="@color/primary"
            app:trackCornerRadius="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="56dp"
            android:text="Menyimpan data..."
            android:textColor="@color/on_background"
            android:textSize="14sp" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
