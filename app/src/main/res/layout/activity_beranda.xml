<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:context=".BerandaActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

    
        <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBarContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="90dp"
        android:background="@color/blue_theme"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

                            <ImageView
            android:id="@+id/iconMenu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/menu"
            android:contentDescription="@string/Menu"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@android:color/white" />

        <ImageView
            android:id="@+id/logoSekolah"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/logo_smk"
            android:contentDescription="Logo SMKN 2"
            app:layout_constraintStart_toEndOf="@id/iconMenu"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tvPageTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Beran"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/logoSekolah"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/textNamaSekolah"
            app:layout_constraintVertical_chainStyle="packed"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/textNamaSekolah"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="SMK Negeri 2 Singosari"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintStart_toStartOf="@id/tvPageTitle"
            app:layout_constraintTop_toBottomOf="@id/tvPageTitle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="8dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBarContent"
        app:layout_constraintBottom_toTopOf="@id/VectorBawah"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:clipChildren="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/spacing_medium"
            android:paddingVertical="@dimen/spacing_large"
            android:clipToPadding="false"
            android:clipChildren="false">

            
            <androidx.cardview.widget.CardView
                android:id="@+id/cardWaktuAbsensi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/spacing_small"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_waktu_absensi"
                app:cardUseCompatPadding="true"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_medium">

                    
                    <ImageView
                        android:id="@+id/iconWarning"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:src="@drawable/ic_peringatan"
                        android:contentDescription="@string/Warning"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintHeight_percent="0.5"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    
                    <TextView
                        android:id="@+id/tvWaktuAbsensi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/WaktuAbsensi"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/text_waktu"
                        android:textStyle="bold"
                        android:layout_marginTop="@dimen/spacing_tiny"
                        app:layout_constraintStart_toEndOf="@id/iconWarning"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/btnAbsensi"
                        android:layout_marginStart="@dimen/spacing_small" />

                    
                    <TextView
                        android:id="@+id/tvDeskripsiAbsensi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/DeskripsiAbsensi"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/text_bawah_waktu"
                        app:layout_constraintStart_toStartOf="@id/tvWaktuAbsensi"
                        app:layout_constraintTop_toBottomOf="@id/tvWaktuAbsensi"
                        app:layout_constraintEnd_toStartOf="@id/btnAbsensi"
                        />

                    
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAbsensi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/Presensi"
                        android:textSize="@dimen/text_small"
                        android:paddingHorizontal="@dimen/spacing_medium"
                        android:paddingVertical="@dimen/spacing_text"
                        android:textColor="@color/card_waktu_absensi"
                        app:backgroundTint="#FFFFFF"
                        app:cornerRadius="8dp"
                        app:rippleColor="#E0E0E0"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/statsContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/cardWaktuAbsensi"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_small"
                android:paddingHorizontal="@dimen/spacing_tiny"
                android:paddingTop="@dimen/spacing_tiny"
                android:paddingBottom="@dimen/spacing_small"
                android:clipToPadding="false"
                android:clipChildren="false">

                
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTotalAbsensi"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/spacing_small"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardUseCompatPadding="true"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/cardTotalAlpha"
                    app:layout_constraintWidth_percent="0.34">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/spacing_medium">

                        <ImageView
                            android:id="@+id/iconTotalAbsensi"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:src="@drawable/ic_total"
                            android:background="@drawable/bg_icon_blue"
                            android:padding="6dp"
                            android:contentDescription="Total Absensi"
                            app:layout_constraintDimensionRatio="1:1"
                            app:layout_constraintHeight_percent="0.35"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/stat_blue_icon_tint" />

                        <TextView
                            android:id="@+id/tvTotalAbsensiLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Total Absensi"
                            android:textColor="@color/stat_blue_text"
                            android:textSize="@dimen/text_button"
                            android:textStyle="bold"
                            android:ellipsize="end"
                            android:maxLines="1"
                            app:layout_constraintStart_toEndOf="@id/iconTotalAbsensi"
                            app:layout_constraintTop_toTopOf="@id/iconTotalAbsensi"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginStart="@dimen/spacing_text" />

                        <TextView
                            android:id="@+id/tvTotalValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/PlaceholderDash"
                            android:textColor="@color/stat_blue_text"
                            android:textSize="@dimen/text_title"
                            android:textStyle="bold"
                            android:gravity="center"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/iconTotalAbsensi"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:layout_marginTop="@dimen/spacing_small" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.cardview.widget.CardView>

                
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTotalAlpha"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/spacing_small"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardUseCompatPadding="true"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cardTotalAbsensi"
                    app:layout_constraintEnd_toStartOf="@id/cardIzinSakit"
                    app:layout_constraintWidth_percent="0.34">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/spacing_medium">

                        <ImageView
                            android:id="@+id/iconTotalAlpha"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:src="@drawable/ic_statistik"
                            android:background="@drawable/bg_icon_red"
                            android:padding="6dp"
                            android:contentDescription="Total Alpha"
                            app:layout_constraintDimensionRatio="1:1"
                            app:layout_constraintHeight_percent="0.35"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/stat_red_icon_tint" />

                        <TextView
                            android:id="@+id/tvTotalAlphaLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Total Alpha"
                            android:textColor="@color/stat_red_text"
                            android:textSize="@dimen/text_button"
                            android:textStyle="bold"
                            android:ellipsize="end"
                            android:maxLines="1"
                            app:layout_constraintStart_toEndOf="@id/iconTotalAlpha"
                            app:layout_constraintTop_toTopOf="@id/iconTotalAlpha"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginStart="@dimen/spacing_text" />

                        <TextView
                            android:id="@+id/tvAlphaValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/PlaceholderDash"
                            android:textColor="@color/stat_red_text"
                            android:textSize="@dimen/text_title"
                            android:textStyle="bold"
                            android:gravity="center"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/iconTotalAlpha"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:layout_marginTop="@dimen/spacing_small" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.cardview.widget.CardView>

                
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardIzinSakit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/spacing_small"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardUseCompatPadding="true"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cardTotalAlpha"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintWidth_percent="0.34">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/spacing_medium">

                        <ImageView
                            android:id="@+id/iconIzinSakit"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:src="@drawable/ic_riwayat"
                            android:background="@drawable/bg_icon_amber"
                            android:padding="6dp"
                            android:contentDescription="Total Izin/Sakit"
                            app:layout_constraintDimensionRatio="1:1"
                            app:layout_constraintHeight_percent="0.35"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/stat_orange_icon_tint" />

                        <TextView
                            android:id="@+id/tvIzinSakitLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Izin/Sakit"
                            android:textColor="@color/stat_orange_text"
                            android:textSize="@dimen/text_button"
                            android:textStyle="bold"
                            android:ellipsize="end"
                            android:maxLines="1"
                            app:layout_constraintStart_toEndOf="@id/iconIzinSakit"
                            app:layout_constraintTop_toTopOf="@id/iconIzinSakit"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginStart="@dimen/spacing_text" />

                        <TextView
                            android:id="@+id/tvIzinSakitValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/PlaceholderDash"
                            android:textColor="@color/stat_orange_text"
                            android:textSize="@dimen/text_title"
                            android:textStyle="bold"
                            android:gravity="center"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/iconIzinSakit"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:layout_marginTop="@dimen/spacing_small" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.cardview.widget.CardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            
            <androidx.cardview.widget.CardView
                android:id="@+id/cardJadwalHariIni"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/spacing_small"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface"
                app:cardUseCompatPadding="true"
                app:layout_constraintTop_toBottomOf="@id/statsContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_small">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_medium">

                    <ImageView
                        android:id="@+id/iconJadwal"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:src="@drawable/ic_jadwal"
                        android:contentDescription="@string/Jadwal"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintTop_toTopOf="@id/tvJadwalLabel"
                        app:layout_constraintBottom_toBottomOf="@id/tvJadwalLabel"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tvJadwalLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/JadwalHariIni"
                        android:textColor="@color/on_background"
                        android:textSize="@dimen/text_section_title"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/iconJadwal"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginStart="@dimen/spacing_small" />

                    
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvJadwalSholat"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvJadwalLabel"
                        android:layout_marginTop="@dimen/spacing_small"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_jadwal_sholat"
                        tools:itemCount="2" />

                    <TextView
                        android:id="@+id/tvJadwalError"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Gagal memuat jadwal"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_small"
                        android:gravity="center"
                        android:paddingVertical="@dimen/spacing_large"
                        android:visibility="gone"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvJadwalLabel"
                        android:layout_marginTop="@dimen/spacing_small" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView
                android:id="@+id/cardRiwayat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/spacing_small"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface"
                app:cardUseCompatPadding="true"
                app:layout_constraintTop_toBottomOf="@id/cardJadwalHariIni"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_small"
                android:layout_marginBottom="@dimen/spacing_large">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_medium">

                    <ImageView
                        android:id="@+id/iconRiwayat"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:src="@drawable/ic_riwayat"
                        android:contentDescription="@string/Riwayat"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintTop_toTopOf="@id/tvRiwayatLabel"
                        app:layout_constraintBottom_toBottomOf="@id/tvRiwayatLabel"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginEnd="0dp" />

                    <TextView
                        android:id="@+id/tvRiwayatLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/Riwayat"
                        android:textColor="@color/on_background"
                        android:textSize="@dimen/text_section_title"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/iconRiwayat"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/btnUnduhRiwayat"
                        android:layout_marginStart="@dimen/spacing_small" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUnduhRiwayat"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/Unduh"
                        android:textSize="11sp"
                        android:textColor="@color/outline_button_blue"
                        app:icon="@drawable/ic_download"
                        app:iconSize="16dp"
                        app:iconTint="@color/outline_button_blue"
                        app:strokeColor="@color/outline_button_blue"
                        app:cornerRadius="8dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvRiwayatLabel"
                        app:layout_constraintBottom_toBottomOf="@id/tvRiwayatLabel" />

                    
                    <LinearLayout
                        android:id="@+id/riwayatHeader"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="@dimen/spacing_small"
                        android:layout_marginTop="@dimen/spacing_small"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvRiwayatLabel">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/Tanggal"
                            android:textStyle="bold"
                            android:textSize="@dimen/text_small"
                            android:textColor="@color/on_background"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/Sholat"
                            android:textStyle="bold"
                            android:textSize="@dimen/text_small"
                            android:textColor="@color/on_background"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/Waktu"
                            android:textStyle="bold"
                            android:textSize="@dimen/text_small"
                            android:textColor="@color/on_background"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/Status"
                            android:textStyle="bold"
                            android:textSize="@dimen/text_small"
                            android:textColor="@color/on_background"
                            android:gravity="center" />
                    </LinearLayout>
                    
                    
                    <View
                        android:id="@+id/dividerHeader"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/riwayatHeader" />


                    
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRiwayatAbsensi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/dividerHeader"
                        tools:listitem="@layout/item_riwayat_absensi"
                        tools:itemCount="6" />

                    <TextView
                        android:id="@+id/tvRiwayatError"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Gagal memuat riwayat"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_small"
                        android:gravity="center"
                        android:paddingVertical="@dimen/spacing_large"
                        android:visibility="gone"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/dividerHeader" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <View
        android:id="@+id/VectorBawah"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/blue_theme"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.065" />

</androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/navigationView"
