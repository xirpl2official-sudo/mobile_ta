<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Validasi Halangan"
            android:textColor="@color/slate_900"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Verifikasi pengajuan halangan siswi sebelum menyetujui."
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <!-- Student Info Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardStudentInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/slate_50">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Row 1: Nama -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvInfoNama"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/slate_900"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    tools:text="Ana Maria" />

                <!-- Row 2: NIS + JK -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NIS"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvInfoNis"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/slate_900"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"
                            tools:text="7781" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jenis Kelamin"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvInfoJk"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/slate_900"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"
                            tools:text="Perempuan" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Row 3: Kelas + Jurusan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kelas"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvInfoKelas"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/slate_900"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp"
                            tools:text="10 RPL A" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jurusan"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvInfoJurusan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/slate_900"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp"
                            tools:text="RPL" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Row 4: Tanggal -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tanggal"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvInfoTanggal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/slate_900"
                        android:textSize="14sp"
                        android:layout_marginTop="2dp"
                        tools:text="10 Juni 2026" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Keterangan Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilKeterangan"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Keterangan">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etKeterangan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="haid"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:id="@+id/dialogActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBatal"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Batal"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:layout_marginEnd="8dp"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTolak"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Tolak"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="@color/status_error"
                android:strokeColor="@color/status_error"
                android:layout_marginEnd="8dp"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSetujui"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Setujui"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="@color/surface"
                android:backgroundTint="@color/status_success"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- Loading overlay -->
        <ProgressBar
            android:id="@+id/dialogProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
