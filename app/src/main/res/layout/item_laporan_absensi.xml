<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="10dp"
    android:background="@color/background">

    <!-- No -->
    <TextView
        android:id="@+id/tvNo"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:text="1"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:paddingHorizontal="4dp"
        android:gravity="center"
        android:contentDescription="Nomor" />

    <!-- Tanggal -->
    <TextView
        android:id="@+id/tvTanggal"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:text="01/01/2025"
        android:textColor="@color/on_background"
        android:textSize="12sp"
        android:paddingHorizontal="4dp"
        android:gravity="center"
        android:contentDescription="Tanggal" />

    <!-- Nama -->
    <TextView
        android:id="@+id/tvNama"
        android:layout_width="110dp"
        android:layout_height="wrap_content"
        android:text="Siswa RPL 5"
        android:textColor="@color/on_background"
        android:textSize="12sp"
        android:paddingHorizontal="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:gravity="start"
        android:contentDescription="Nama Siswa" />

    <!-- Kelas -->
    <TextView
        android:id="@+id/tvKelas"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="11 RPL"
        android:textColor="@color/on_background"
        android:textSize="12sp"
        android:paddingHorizontal="4dp"
        android:gravity="center"
        android:contentDescription="Kelas" />

    <!-- Sholat -->
    <TextView
        android:id="@+id/tvSholat"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="Duha"
        android:textColor="@color/on_background"
        android:textSize="12sp"
        android:paddingHorizontal="4dp"
        android:gravity="center"
        android:contentDescription="Jenis Shalat" />

    <!-- Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:text="Hadir"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:gravity="center"
        android:background="@drawable/bg_status_hadir"
        android:contentDescription="Status Kehadiran" />

</LinearLayout>
