<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:elevation="8dp">

    <!-- Header Sidebar: Blue Background, NO fitsSystemWindows here as padding is dynamic -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/sidebarHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/blue_theme"
        android:padding="16dp"
        android:paddingBottom="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvMenuTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Menu"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvMenuSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Absensi Sholat"
            android:textColor="#DBEAFE"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMenuTitle" />

        <ImageView
            android:id="@+id/btnCloseSidebar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:contentDescription="Close"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@android:color/white" />

        <!-- User Profile Card: Embedded INSIDE Blue Header -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardUserProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#EFF6FF"
            app:layout_constraintTop_toBottomOf="@id/tvMenuSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/white">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_user_profile"
                        android:padding="10dp"
                        android:contentDescription="User Profile"
                        app:tint="@color/blue_theme" />

                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tvAdminName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Admin"
                        android:textColor="#1F2937"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAdminRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Administrator"
                        android:textColor="#6B7280"
                        android:textSize="12sp"
                        android:layout_marginTop="1dp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Menu Items in White Body -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/sidebarHeader"
        app:layout_constraintBottom_toTopOf="@id/dividerSettings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/menuItemsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp">

            <!-- Item Beranda -->
            <LinearLayout
                android:id="@+id/menuBeranda"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="4dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_home" app:tint="@color/icon_sidebar_inactive" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Beranda" android:textColor="@color/text_sidebar_inactive" android:textSize="14sp" android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- Item Jadwal Sholat -->
            <LinearLayout
                android:id="@+id/menuJadwalSholat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="4dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_jadwal" app:tint="@color/icon_sidebar_inactive" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Jadwal Sholat" android:textColor="@color/text_sidebar_inactive" android:textSize="14sp" android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- Item Data Siswa -->
            <LinearLayout
                android:id="@+id/menuDataSiswa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="4dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/users" app:tint="@color/icon_sidebar_inactive" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Data Siswa" android:textColor="@color/text_sidebar_inactive" android:textSize="14sp" android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- Item Kelola Kelas -->
            <LinearLayout
                android:id="@+id/menuKelolaKelas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="4dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/gear" app:tint="@color/icon_sidebar_inactive" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Kelola Kelas" android:textColor="@color/text_sidebar_inactive" android:textSize="14sp" android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- Item Presensi -->
            <LinearLayout
                android:id="@+id/menuPresensi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="4dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/clipboard" app:tint="@color/icon_sidebar_inactive" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Presensi" android:textColor="@color/text_sidebar_inactive" android:textSize="14sp" android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- Item Laporan -->
            <LinearLayout
                android:id="@+id/menuLaporan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="4dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/bar" app:tint="@color/icon_sidebar_inactive" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Laporan" android:textColor="@color/text_sidebar_inactive" android:textSize="14sp" android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- Item Pengajuan Izin -->
            <LinearLayout
                android:id="@+id/menuPengajuanIzin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="4dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_perizinan" app:tint="@color/icon_sidebar_inactive" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Pengajuan Izin" android:textColor="@color/text_sidebar_inactive" android:textSize="14sp" android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- Item QR Code -->
            <LinearLayout
                android:id="@+id/menuQRCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="4dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_qr_code" app:tint="@color/icon_sidebar_inactive" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="QR Code" android:textColor="@color/text_sidebar_inactive" android:textSize="14sp" android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- Item Siswa Belum Terdaftar -->
            <LinearLayout
                android:id="@+id/menuSiswaBelumTerdaftar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="4dp">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_user_profile" app:tint="@color/icon_sidebar_inactive" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Siswa Belum Terdaftar" android:textColor="@color/text_sidebar_inactive" android:textSize="14sp" android:layout_marginStart="12dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <View
        android:id="@+id/dividerSettings"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#F3F4F6"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintBottom_toTopOf="@id/menuPengaturan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

    <!-- Item Pengaturan -->
    <LinearLayout
        android:id="@+id/menuPengaturan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintBottom_toTopOf="@id/menuLogout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/settings" app:tint="@color/icon_sidebar_inactive" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Pengaturan" android:textColor="@color/text_sidebar_inactive" android:textSize="14sp" android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Item Logout -->
    <LinearLayout
        android:id="@+id/menuLogout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_logout" app:tint="@color/text_danger" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Keluar" android:textColor="@color/text_danger" android:textSize="14sp" android:layout_marginStart="12dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>