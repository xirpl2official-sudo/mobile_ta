<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/sidebar_width"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:elevation="8dp">

    <!-- Header Sidebar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/sidebarHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/blue_theme"
        android:paddingBottom="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Top text and close button padding container -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerTopSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            app:layout_constraintTop_toTopOf="parent">
            
            <TextView
                android:id="@+id/tvMenuTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/btnCloseSidebar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:contentDescription="Tutup menu"
                android:src="@drawable/ic_close"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvMenuTitle"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/tvMenuSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Absensi Shalat"
                android:textColor="@color/slate_200"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvMenuTitle" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- User Profile Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUserProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/headerTopSection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_circle_light_blue">

                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="Foto profil"
                        android:src="@drawable/ic_user_profile"
                        app:tint="@color/blue_theme" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAdminName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Budi Santoso"
                        android:textColor="@color/slate_800"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAdminRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Administrator"
                        android:textColor="@color/slate_500"
                        android:textSize="12sp" />
                        
                    <TextView
                        android:id="@+id/tvAdminEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Items -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sidebarHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <!-- Item Dashboard / Beranda -->
            <LinearLayout
                android:id="@+id/menuBeranda"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_home" android:contentDescription="Beranda" app:tint="@color/slate_500" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Beranda" android:textColor="@color/slate_700" android:textSize="15sp" />
            </LinearLayout>

            <!-- Item Jadwal -->
            <LinearLayout
                android:id="@+id/menuJadwalSholat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_clock" android:contentDescription="Jadwal Sholat" app:tint="@color/slate_500" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Jadwal Shalat" android:textColor="@color/slate_700" android:textSize="15sp" />
            </LinearLayout>

            <!-- Item Kelola Siswa -->
            <LinearLayout
                android:id="@+id/menuDataSiswa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/users" android:contentDescription="Kelola Siswa" app:tint="@color/slate_500" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Kelola Siswa" android:textColor="@color/slate_700" android:textSize="15sp" />
            </LinearLayout>


            <!-- Item Kelola Kelas -->
            <LinearLayout
                android:id="@+id/menuKelolaKelas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_class" android:contentDescription="Kelola Kelas" app:tint="@color/slate_500" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Kelola Kelas" android:textColor="@color/slate_700" android:textSize="15sp" />
            </LinearLayout>

            <!-- Item Kelola Guru -->
            <LinearLayout
                android:id="@+id/menuKelolaGuru"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_user_profile" android:contentDescription="Kelola Guru" app:tint="@color/slate_500" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Kelola Guru" android:textColor="@color/slate_700" android:textSize="15sp" />
            </LinearLayout>

            <!-- Item Presensi -->
            <LinearLayout
                android:id="@+id/menuPresensi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_calendar" android:contentDescription="Presensi" app:tint="@color/slate_500" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Presensi" android:textColor="@color/slate_700" android:textSize="15sp" />
            </LinearLayout>

            <!-- Item Pengajuan Izin -->
            <LinearLayout
                android:id="@+id/menuPengajuanIzin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_perizinan" android:contentDescription="Pengajuan Izin" app:tint="@color/slate_500" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Pengajuan Izin" android:textColor="@color/slate_700" android:textSize="15sp" />
            </LinearLayout>

            <!-- Item Laporan -->
            <LinearLayout
                android:id="@+id/menuLaporan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_statistik" android:contentDescription="Laporan" app:tint="@color/slate_500" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Laporan" android:textColor="@color/slate_700" android:textSize="15sp" />
            </LinearLayout>

            <!-- Item QR Code -->
            <LinearLayout
                android:id="@+id/menuQRCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_qr_code" android:contentDescription="QR Code" app:tint="@color/slate_500" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Kode QR" android:textColor="@color/slate_700" android:textSize="15sp" />
            </LinearLayout>

            <!-- Item Siswa Belum Terdaftar -->
            <LinearLayout
                android:id="@+id/menuSiswaBelumTerdaftar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_user_profile" android:contentDescription="Siswa Belum Terdaftar" app:tint="@color/slate_500" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Siswa Belum Terdaftar" android:textColor="@color/slate_700" android:textSize="15sp" />
            </LinearLayout>

            <!-- Item Perangkat Siswa -->
            <LinearLayout
                android:id="@+id/menuManajemenPerangkat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_device" android:contentDescription="Perangkat Siswa" app:tint="@color/slate_500" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Perangkat Siswa" android:textColor="@color/slate_700" android:textSize="15sp" />
            </LinearLayout>

            <!-- Item Kenaikan Kelas -->
            <LinearLayout
                android:id="@+id/menuKenaikanKelas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_class" android:contentDescription="Kenaikan Kelas" app:tint="@color/slate_500" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Kenaikan Kelas" android:textColor="@color/slate_700" android:textSize="15sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="12dp"
                android:layout_marginHorizontal="8dp" />

            <!-- Item Pusat Bantuan -->
            <LinearLayout
                android:id="@+id/menuFAQ"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_info" android:contentDescription="Pusat Bantuan" app:tint="@color/slate_500" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Pusat Bantuan" android:textColor="@color/slate_700" android:textSize="15sp" />
            </LinearLayout>

            <!-- Item Pengaturan -->
            <LinearLayout
                android:id="@+id/menuPengaturan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/gear" android:contentDescription="Pengaturan" app:tint="@color/slate_500" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Pengaturan" android:textColor="@color/slate_700" android:textSize="15sp" />
            </LinearLayout>

            <!-- Item Logout -->
            <LinearLayout
                android:id="@+id/menuLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_logout" android:contentDescription="Keluar" app:tint="@color/error_color" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Keluar" android:textColor="@color/error_color" android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>