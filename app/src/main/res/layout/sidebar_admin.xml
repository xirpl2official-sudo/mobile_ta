<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:background="@color/sidebar_bg"
    android:elevation="8dp">

    <!-- Header Sidebar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/sidebarHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/logoIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_sun"
            app:tint="#F97316"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvMenuTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Absensholat"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/tvMenuSubtitle"
            app:layout_constraintEnd_toStartOf="@id/btnCloseSidebar"
            app:layout_constraintStart_toEndOf="@id/logoIcon"
            app:layout_constraintTop_toTopOf="@id/logoIcon" />

        <TextView
            android:id="@+id/tvMenuSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Portal Administrator"
            android:textColor="@color/sidebar_text_secondary"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/logoIcon"
            app:layout_constraintEnd_toEndOf="@id/tvMenuTitle"
            app:layout_constraintStart_toStartOf="@id/tvMenuTitle" />

        <ImageView
            android:id="@+id/btnCloseSidebar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="Close"
            android:src="@drawable/ic_close"
            android:alpha="0.6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@android:color/white" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Items -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/sidebarHeader"
        app:layout_constraintBottom_toTopOf="@id/cardUserProfile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp">

            <!-- Item Dashboard -->
            <LinearLayout
                android:id="@+id/menuBeranda"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_home" app:tint="@color/sidebar_text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Dashboard" android:textColor="@color/sidebar_text_secondary" android:textSize="14sp" />
            </LinearLayout>

            <!-- Item Jadwal -->
            <LinearLayout
                android:id="@+id/menuJadwalSholat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_calendar" app:tint="@color/sidebar_text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Jadwal" android:textColor="@color/sidebar_text_secondary" android:textSize="14sp" />
            </LinearLayout>

            <!-- Item Data Siswa -->
            <LinearLayout
                android:id="@+id/menuDataSiswa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/users" app:tint="@color/sidebar_text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Data Siswa" android:textColor="@color/sidebar_text_secondary" android:textSize="14sp" />
            </LinearLayout>

            <!-- Item Kelola Siswa -->
            <LinearLayout
                android:id="@+id/menuKelolaSiswa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/gear" app:tint="@color/sidebar_text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Kelola Siswa" android:textColor="@color/sidebar_text_secondary" android:textSize="14sp" />
            </LinearLayout>

            <!-- Item Kelola Kelas -->
            <LinearLayout
                android:id="@+id/menuKelolaKelas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/gear" app:tint="@color/sidebar_text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Kelola Kelas" android:textColor="@color/sidebar_text_secondary" android:textSize="14sp" />
            </LinearLayout>

            <!-- Item Presensi -->
            <LinearLayout
                android:id="@+id/menuPresensi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_riwayat" app:tint="@color/sidebar_text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Presensi" android:textColor="@color/sidebar_text_secondary" android:textSize="14sp" />
            </LinearLayout>

            <!-- Item Pengajuan Izin -->
            <LinearLayout
                android:id="@+id/menuPengajuanIzin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_perizinan" app:tint="@color/sidebar_text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Pengajuan Izin" android:textColor="@color/sidebar_text_secondary" android:textSize="14sp" />
            </LinearLayout>

            <!-- Item Laporan -->
            <LinearLayout
                android:id="@+id/menuLaporan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_statistik" app:tint="@color/sidebar_text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Laporan" android:textColor="@color/sidebar_text_secondary" android:textSize="14sp" />
            </LinearLayout>

            <!-- Item QR Code -->
            <LinearLayout
                android:id="@+id/menuQRCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_qr_code" app:tint="@color/sidebar_text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="QR Code" android:textColor="@color/sidebar_text_secondary" android:textSize="14sp" />
            </LinearLayout>

            <!-- Item Siswa Belum Terdaftar -->
            <LinearLayout
                android:id="@+id/menuSiswaBelumTerdaftar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_add" app:tint="@color/sidebar_text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Siswa Belum Terdaftar" android:textColor="@color/sidebar_text_secondary" android:textSize="14sp" />
            </LinearLayout>

            <!-- Item Manajemen Perangkat -->
            <LinearLayout
                android:id="@+id/menuManajemenPerangkat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/gear" app:tint="@color/sidebar_text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Manajemen Perangkat" android:textColor="@color/sidebar_text_secondary" android:textSize="14sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" android:layout_marginVertical="8dp" />

            <!-- Item Pengaturan -->
            <LinearLayout
                android:id="@+id/menuPengaturan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/gear" app:tint="@color/sidebar_text_secondary" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Pengaturan" android:textColor="@color/sidebar_text_secondary" android:textSize="14sp" />
            </LinearLayout>

            <!-- Item Logout -->
            <LinearLayout
                android:id="@+id/menuLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_sidebar_item_selector">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_logout" app:tint="@color/error_color" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Keluar" android:textColor="@color/error_color" android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- User Profile Card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardUserProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="#173691"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_user_profile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@color/sidebar_text_secondary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/ivAvatar"
            app:layout_constraintEnd_toStartOf="@id/ivExpand"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvAdminName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Budi Santoso"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAdminEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="admin@sekolah.sch.id"
                android:textColor="@color/sidebar_text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvAdminRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Administrator"
                android:textColor="@color/sidebar_text_secondary"
                android:textSize="10sp"
                android:visibility="gone" />

        </LinearLayout>

        <ImageView
            android:id="@+id/ivExpand"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_right"
            android:rotation="90"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@color/sidebar_text_secondary" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>