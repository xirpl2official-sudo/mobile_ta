<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="8dp">

    <!-- Kelas Header -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardKelas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="1dp"
        app:strokeColor="@color/outline"
        app:strokeWidth="1dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/kelasHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/tvNamaKelas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="X RPL 1"
                    android:textColor="@color/on_background"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/badgeSiswaCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_status_gray"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="36 Siswa"
                    android:textColor="@color/on_background"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/tvNamaKelas"
                    app:layout_constraintTop_toTopOf="@id/tvNamaKelas"
                    app:layout_constraintBottom_toBottomOf="@id/tvNamaKelas" />

                <!-- Wali Info -->
                <LinearLayout
                    android:id="@+id/layoutWaliInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="4dp"
                    android:layout_marginTop="6dp"
                    app:layout_constraintTop_toBottomOf="@id/tvNamaKelas"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/ivExpandKelas">

                    <TextView
                        android:id="@+id/tvWaliKelas"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Wali belum diatur"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUbahWaliQuick"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Atur Wali"
                        android:textSize="11sp"
                        android:minWidth="80dp"
                        android:layout_marginStart="4dp" />

                    <ProgressBar
                        android:id="@+id/pbSavingWali"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:visibility="gone"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivExpandKelas"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="Perluas"
                    android:src="@drawable/ic_chevron_right"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvNamaKelas"
                    app:layout_constraintBottom_toBottomOf="@id/tvNamaKelas"
                    app:tint="@color/text_hint" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Expandable: Student List -->
            <LinearLayout
                android:id="@+id/layoutExpandableKelas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="8dp" />

                <!-- Kelola Wali Section -->
                <LinearLayout
                    android:id="@+id/sectionWali"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_outline"
                    android:padding="10dp"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Wali kelas"
                        android:src="@drawable/ic_user_profile"
                        app:tint="@color/primary"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wali Kelas"
                            android:textColor="@color/on_background"
                            android:textStyle="bold"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pilih guru yang bertanggung jawab."
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUbahWaliSection"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Atur Wali"
                        android:textSize="11sp"
                        app:strokeColor="@color/primary"
                        android:textColor="@color/primary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDaftarSiswaTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daftar Siswa"
                    android:textColor="@color/on_background"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Student Table -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/surface"
                    app:strokeColor="@color/outline"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="6dp"
                            android:background="@color/slate_100">

                            <View
                                android:layout_width="36dp"
                                android:layout_height="match_parent" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.08"
                                android:text="No"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.20"
                                android:text="NIS"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.40"
                                android:text="Nama"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:paddingHorizontal="4dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.12"
                                android:text="JK"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.20"
                                android:text="Aksi"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:gravity="center" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerSiswaInClass"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                        <ProgressBar
                            android:id="@+id/pbLoadingSiswa"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:layout_margin="12dp"
                            android:visibility="gone" />

                        <!-- Empty State for Students -->
                        <LinearLayout
                            android:id="@+id/emptyStateSiswa"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="20dp"
                            android:visibility="gone">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:contentDescription="Tidak ada siswa"
                                android:src="@drawable/users"
                                app:tint="@color/slate_300" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Belum ada siswa di kelas ini."
                                android:textColor="@color/slate_600"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp" />

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
