<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="#E2E8F0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/tvNamaKelas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="XII RPL 1"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/badgeSiswaCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_status_gray"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="36 Siswa"
                android:textColor="#64748B"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/tvNamaKelas"
                app:layout_constraintStart_toEndOf="@id/tvNamaKelas"
                app:layout_constraintTop_toTopOf="@id/tvNamaKelas" />

            <TextView
                android:id="@+id/labelWaliKelas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Wali Kelas:"
                android:textColor="#64748B"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvNamaKelas" />

            <TextView
                android:id="@+id/tvWaliKelas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Budi Santoso, S.Kom"
                android:textColor="#334155"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/labelWaliKelas"
                app:layout_constraintEnd_toStartOf="@id/btnUbahWali"
                app:layout_constraintStart_toEndOf="@id/labelWaliKelas"
                app:layout_constraintTop_toTopOf="@id/labelWaliKelas" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUbahWali"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="Ubah"
                android:textColor="@color/primary"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ivExpand"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="4dp"
                android:src="@drawable/ic_chevron_right"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnUbahWali"
                app:tint="#94A3B8" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Content (Expandable) -->
        <LinearLayout
            android:id="@+id/layoutExpandable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F1F5F9"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvDaftarSiswaTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daftar Siswa (36)"
                android:textColor="#0F172A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Table Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:background="#F8FAFC">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.08"
                    android:text="No"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#64748B"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.20"
                    android:text="NIS"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#64748B"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.40"
                    android:text="Nama"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#64748B"
                    android:paddingHorizontal="4dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.12"
                    android:text="JK"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#64748B"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.20"
                    android:text="Aksi"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#64748B"
                    android:gravity="center" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerSiswaInClass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <ProgressBar
                android:id="@+id/pbLoadingSiswa"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:layout_margin="16dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>