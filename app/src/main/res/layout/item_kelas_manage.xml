<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Jurusan Header -->
    <LinearLayout
        android:id="@+id/layoutJurusanHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp"
        android:layout_marginTop="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvJurusanTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RPL"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary" />

        <TextView
            android:id="@+id/tvJurusanCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_status_gray"
            android:textColor="@color/on_background"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="3 Kelas"
            android:textSize="12sp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/outline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/ivJurusanLogo"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:src="@drawable/ic_class" />

                <TextView
                    android:id="@+id/tvNamaKelas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XII RPL 1"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/ivJurusanLogo"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/badgeSiswaCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_status_gray"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="36 Siswa"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/tvNamaKelas"
                    app:layout_constraintStart_toEndOf="@id/tvNamaKelas"
                    app:layout_constraintTop_toTopOf="@id/tvNamaKelas" />

                <!-- Warning Badge for Missing Wali Kelas -->
                <LinearLayout
                    android:id="@+id/layoutWaliInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tvNamaKelas"
                    app:layout_constraintStart_toEndOf="@id/ivJurusanLogo"
                    app:layout_constraintEnd_toStartOf="@id/ivExpand">
                    
                    <TextView
                        android:id="@+id/tvWaliKelas"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Wali belum ditentukan"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                        
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUbahWaliQuick"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Atur Wali"
                        android:textSize="11sp"
                        android:layout_marginStart="8dp" />

                    <ProgressBar
                        android:id="@+id/pbSavingWali"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:visibility="gone"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivExpand"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="Perluas"
                    android:src="@drawable/ic_chevron_right"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/text_hint" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Content (Expandable) -->
            <LinearLayout
                android:id="@+id/layoutExpandable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="16dp"
                android:visibility="gone"
                android:background="@color/surface">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="12dp" />

                <!-- Empty State for 0 Students -->
                <LinearLayout
                    android:id="@+id/emptyStateSiswa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone">
                    
                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:contentDescription="Tidak ada siswa"
                        android:src="@drawable/users"
                        app:tint="@color/slate_300" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Belum ada siswa di kelas ini."
                        android:textColor="@color/slate_600"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tambahkan siswa sekarang."
                        android:textColor="@color/slate_500"
                        android:textSize="12sp"
                        android:gravity="center"/>
                        
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmptyTambahSiswa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Tambah Siswa"
                        app:icon="@drawable/ic_user_profile"
                        app:cornerRadius="8dp" />
                </LinearLayout>

                <!-- Kelola Wali Kelas Section -->
                <LinearLayout
                    android:id="@+id/sectionWali"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_outline"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp">
                    
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Profil siswa"
                        android:src="@drawable/ic_user_profile"
                        app:tint="@color/primary"
                        android:layout_marginEnd="12dp"/>
                        
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvSectionWaliTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wali Kelas"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvSectionWaliSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pilih guru yang bertanggung jawab atas kelas ini."
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"/>
                    </LinearLayout>
                    
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUbahWaliSection"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Atur Wali"
                        android:textSize="12sp"
                        app:strokeColor="@color/primary"
                        android:textColor="@color/primary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDaftarSiswaTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daftar Siswa (36)"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/surface"
                    app:strokeColor="@color/outline"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <!-- Table Header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp"
                            android:background="@color/slate_100">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.08"
                                android:text="No"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.20"
                                android:text="NIS"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.40"
                                android:text="Nama"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:paddingHorizontal="4dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.12"
                                android:text="JK"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.20"
                                android:text="Aksi"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:gravity="center" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerSiswaInClass"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                        <ProgressBar
                            android:id="@+id/pbLoadingSiswa"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:layout_margin="16dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>