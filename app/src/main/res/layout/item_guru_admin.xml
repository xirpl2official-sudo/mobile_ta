<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="8dp"
    android:background="@color/background">

    <!-- Nama -->
    <TextView
        android:id="@+id/tvNama"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:textColor="@color/on_background"
        android:textSize="12sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="1"
        tools:text="Nama Guru, S.Pd" />

    <!-- NIP -->
    <TextView
        android:id="@+id/tvNip"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="2dp"
        android:textColor="@color/on_background"
        android:textSize="12sp"
        android:ellipsize="end"
        android:maxLines="1"
        tools:text="19800101 200501 1 001" />

    <!-- Email -->
    <TextView
        android:id="@+id/tvEmail"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:paddingHorizontal="4dp"
        android:textColor="@color/on_background"
        android:textSize="12sp"
        android:ellipsize="end"
        android:maxLines="1"
        tools:text="guru@smkn2singosari.sch.id" />

    <!-- Wali Kelas -->
    <TextView
        android:id="@+id/tvWaliKelas"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="2dp"
        android:paddingVertical="4dp"
        android:textSize="10sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="1"
        tools:background="@drawable/bg_badge_jurusan"
        tools:text="XII RPL 2"
        tools:textColor="@color/blue_theme" />

    <!-- Aksi -->
    <LinearLayout
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingEnd="4dp">

        <ImageView
            android:id="@+id/btnEdit"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="5dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Edit Data Guru"
            android:src="@drawable/ic_edit"
            app:tint="@color/blue_theme" />

        <ImageView
            android:id="@+id/btnLepasWaliKelas"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="5dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Lepaskan sebagai Wali Kelas"
            android:src="@drawable/ic_close"
            app:tint="@color/orange"
            android:visibility="gone"
            tools:visibility="visible" />

        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="5dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Hapus Data"
            android:src="@drawable/ic_delete"
            app:tint="@color/error_color" />

    </LinearLayout>

</LinearLayout>
