<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="8dp"
    android:background="@color/background">

    <!-- Nama -->
    <TextView
        android:id="@+id/tvNama"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:textColor="@color/on_background"
        android:textSize="12sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="1"
        tools:text="Nama Guru, S.Pd" />

    <!-- NIP -->
    <TextView
        android:id="@+id/tvNip"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="2dp"
        android:textColor="@color/on_background"
        android:textSize="12sp"
        android:ellipsize="end"
        android:maxLines="1"
        tools:text="19800101 200501 1 001" />

    <!-- Email -->
    <TextView
        android:id="@+id/tvEmail"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:paddingHorizontal="4dp"
        android:textColor="@color/on_background"
        android:textSize="12sp"
        android:ellipsize="end"
        android:maxLines="1"
        tools:text="guru@smkn2singosari.sch.id" />

    <!-- Wali Kelas -->
    <TextView
        android:id="@+id/tvWaliKelas"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="2dp"
        android:paddingVertical="4dp"
        android:textSize="10sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="1"
        tools:background="@drawable/bg_badge_jurusan"
        tools:text="XII RPL 2"
        tools:textColor="@color/blue_theme" />

    <!-- Aksi (3-dot menu) -->
    <FrameLayout
        android:layout_width="90dp"
        android:layout_height="36dp">
        
        <ImageView
            android:id="@+id/btnMoreMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Menu Aksi"
            android:src="@drawable/ic_more_vert"
            android:scaleType="centerInside"
            app:tint="@color/slate_600" />
            
    </FrameLayout>

</LinearLayout>
