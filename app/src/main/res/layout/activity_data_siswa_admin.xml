<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main Content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        tools:context=".DataSiswaAdminActivity">

        <!-- Vector Background untuk Toolbar -->
        <View
            android:id="@+id/VectorAtasMenu"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_menu_atas"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.08" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/topBarContent"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@android:color/transparent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.08">

            <!-- Icon Menu (Kiri) -->
            <ImageView
                android:id="@+id/iconMenu"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:src="@drawable/menu"
                android:contentDescription="@string/Menu"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintHeight_percent="0.4"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Logo Sekolah -->
            <ImageView
                android:id="@+id/logoSekolah"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:src="@drawable/logo_smk"
                android:contentDescription="@string/LogoSMKN2"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintHeight_percent="0.8"
                app:layout_constraintStart_toEndOf="@id/iconMenu"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginStart="14dp" />

            <!-- Text Data Siswa -->
            <TextView
                android:id="@+id/textDashboard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/DataSiswa"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_beranda"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/logoSekolah"
                app:layout_constraintTop_toTopOf="@id/logoSekolah"
                app:layout_constraintBottom_toTopOf="@id/textNamaSekolah"
                app:layout_constraintVertical_chainStyle="packed"
                android:layout_marginStart="10dp" />

            <!-- Text Nama Sekolah -->
            <TextView
                android:id="@+id/textNamaSekolah"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/Stemdasi"
                android:textColor="#E0E0E0"
                android:textSize="@dimen/text_smkn2s"
                android:ellipsize="end"
                android:maxLines="1"
                app:layout_constraintStart_toStartOf="@id/textDashboard"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textDashboard"
                app:layout_constraintBottom_toBottomOf="@id/logoSekolah"
                android:layout_marginEnd="8dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Content Area (Fixed Header + Scrollable Table) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/contentArea"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/topBarContent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:padding="16dp">

            <!-- Fixed Header: Title + Tambah Button -->
            <LinearLayout
                android:id="@+id/headerRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/DataSiswa"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTambah"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/Tambah"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    app:icon="@android:drawable/ic_input_add"
                    app:iconTint="@android:color/white"
                    app:backgroundTint="#2196F3"
                    app:cornerRadius="8dp" />

            </LinearLayout>

            <!-- Search Bar -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_search_input"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="12dp"
                android:hint="cari siswa"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/headerRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Filters Row -->
            <LinearLayout
                android:id="@+id/filtersRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/etSearch"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/filterKelas"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_dropdown"
                    android:drawableEnd="@drawable/ic_chevron_right"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="10dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/SemuaKelas"
                    android:textColor="#666666"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/filterJurusan"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_dropdown"
                    android:drawableEnd="@drawable/ic_chevron_right"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="10dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/SemuaJurusan"
                    android:textColor="#666666"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/filterGender"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_dropdown"
                    android:drawableEnd="@drawable/ic_chevron_right"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="10dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/SemuaJK"
                    android:textColor="#666666"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Count Info -->
            <TextView
                android:id="@+id/tvCountInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/MenampilkanSiswa"
                android:textColor="#666666"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/filtersRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Loading Progress Bar -->
            <ProgressBar
                android:id="@+id/progressLoading"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tvCountInfo"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Empty State Text -->
            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/TidakDitemukanSiswa"
                android:textColor="#666666"
                android:textSize="14sp"
                android:gravity="center"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tvCountInfo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Horizontal Scrollable Table with RecyclerView -->
            <HorizontalScrollView
                android:id="@+id/tableHorizontalScrollView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:fillViewport="true"
                app:layout_constraintTop_toBottomOf="@id/tvCountInfo"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <!-- Table Header -->
                    <LinearLayout
                        android:id="@+id/tableHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="#2196F3"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="@string/NIS"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="8dp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="150dp"
                            android:layout_height="wrap_content"
                            android:text="@string/Nama"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="8dp"
                            android:gravity="start" />

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="@string/JK"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="4dp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:text="@string/Kelas"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="4dp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="@string/Jurusan"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="8dp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Keterangan"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="8dp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="@string/Aksi"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="8dp"
                            android:gravity="center" />

                    </LinearLayout>

                    <!-- RecyclerView for Table Body -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerSiswa"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:scrollbars="vertical" />

                </LinearLayout>

            </HorizontalScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer (Sidebar) -->
    <include
        android:id="@+id/navigationView"
        layout="@layout/sidebar_data_siswa"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
