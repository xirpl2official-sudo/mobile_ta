<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="10dp"
    android:paddingHorizontal="8dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">

    <TextView
        android:id="@+id/tvPendingNis"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textStyle="bold"
        android:textSize="12sp"
        android:textColor="@color/slate_900"
        android:layout_marginEnd="4dp"
        tools:text="7781" />

    <TextView
        android:id="@+id/tvPendingNama"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:textSize="12sp"
        android:textColor="@color/slate_700"
        android:ellipsize="end"
        android:maxLines="1"
        android:layout_marginEnd="4dp"
        tools:text="Ana Maria" />

    <TextView
        android:id="@+id/tvPendingKelas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:textSize="12sp"
        android:textColor="@color/slate_600"
        android:ellipsize="end"
        android:maxLines="1"
        android:layout_marginEnd="4dp"
        tools:text="10 RPL A" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPendingValidasi"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_weight="0.8"
        android:text="Validasi"
        android:textSize="10sp"
        android:textAllCaps="false"
        app:cornerRadius="6dp" />

</LinearLayout>
