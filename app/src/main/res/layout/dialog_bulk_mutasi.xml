<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pindahkan siswa terpilih ke:"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jurusan"
            android:textColor="@color/on_background"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerTargetJurusan"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_dropdown"
            android:layout_marginBottom="16dp"
            android:popupBackground="@color/surface" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kelas"
            android:textColor="@color/on_background"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerTargetKelas"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_dropdown"
            android:layout_marginBottom="16dp"
            android:popupBackground="@color/surface" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status Baru (Opsional)"
            android:textColor="@color/on_background"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerTargetStatus"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_dropdown"
            android:layout_marginBottom="8dp"
            android:popupBackground="@color/surface" />

    </LinearLayout>
</ScrollView>
