<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="12dp"
    android:background="@android:color/white">

    <CheckBox
        android:id="@+id/cbRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:layout_marginStart="8dp" />

    <TextView
        android:id="@+id/tvNis"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:text="6896/805.027"
        android:textSize="11sp"
        android:textColor="@color/qr_text_primary"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvNama"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.8"
        android:text="Aditia Firmansyah"
        android:textSize="11sp"
        android:textColor="@color/qr_text_primary"
        android:paddingHorizontal="4dp"
        android:ellipsize="end"
        android:maxLines="1" />

    <TextView
        android:id="@+id/tvKelas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:text="12 TAV 1"
        android:textSize="10sp"
        android:textColor="@color/qr_text_secondary"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvJurusan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:text="TAV"
        android:textSize="10sp"
        android:textColor="@color/qr_text_secondary"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvWaliKelas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Pak Budi"
        android:textSize="10sp"
        android:textColor="@color/qr_text_secondary"
        android:gravity="center" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDetail"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="30dp"
        android:layout_weight="1"
        android:text="Detail"
        android:textSize="10sp"
        android:padding="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:layout_marginEnd="4dp"
        app:strokeColor="@color/qr_primary"
        app:strokeWidth="1dp"
        android:textColor="@color/qr_primary"
        app:cornerRadius="6dp" />

</LinearLayout>