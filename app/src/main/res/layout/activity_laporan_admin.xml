<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start">

    <!-- Main Content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        tools:context=".LaporanAdminActivity">

        <!-- Vector Background untuk Toolbar -->
        <View
            android:id="@+id/VectorAtasMenu"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_menu_atas"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.08" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/topBarContent"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@android:color/transparent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.08">

            <!-- Icon Menu (Kiri) -->
            <ImageView
                android:id="@+id/iconMenu"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:src="@drawable/menu"
                android:contentDescription="@string/Menu"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintHeight_percent="0.4"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Logo Sekolah -->
            <ImageView
                android:id="@+id/logoSekolah"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:src="@drawable/logo_smk"
                android:contentDescription="@string/LogoSMKN2"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintHeight_percent="0.8"
                app:layout_constraintStart_toEndOf="@id/iconMenu"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginStart="14dp" />

            <!-- Text Laporan -->
            <TextView
                android:id="@+id/textDashboard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/Laporan"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_beranda"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/logoSekolah"
                app:layout_constraintTop_toTopOf="@id/logoSekolah"
                app:layout_constraintBottom_toTopOf="@id/textNamaSekolah"
                app:layout_constraintVertical_chainStyle="packed"
                android:layout_marginStart="10dp" />

            <!-- Text Nama Sekolah -->
            <TextView
                android:id="@+id/textNamaSekolah"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/Stemdasi"
                android:textColor="#E0E0E0"
                android:textSize="@dimen/text_smkn2s"
                android:ellipsize="end"
                android:maxLines="1"
                app:layout_constraintStart_toStartOf="@id/textDashboard"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textDashboard"
                app:layout_constraintBottom_toBottomOf="@id/logoSekolah"
                android:layout_marginEnd="8dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Content Area - Scrollable Content -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/mainScrollView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintTop_toBottomOf="@id/topBarContent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Title: Laporan Presensi -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/LaporanPresensi"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Filter Laporan Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/FilterLaporan"
                            android:textColor="#000000"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <!-- Tanggal Awal -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/TanggalAwal"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvTanggalAwal"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_dropdown"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:text="@string/PlaceholderTanggalAwal"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp" />

                        <!-- Tanggal Akhir -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/TanggalAkhir"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvTanggalAkhir"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_dropdown"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:text="@string/PlaceholderTanggalAkhir"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp" />

                        <!-- Jurusan -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/Jurusan"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvFilterJurusan"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_dropdown"
                            android:drawableEnd="@drawable/ic_chevron_right"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:text="@string/SemuaJurusan"
                            android:textColor="#666666"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp" />

                        <!-- Kelas -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/Kelas"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvFilterKelas"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_dropdown"
                            android:drawableEnd="@drawable/ic_chevron_right"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:text="@string/SemuaKelas"
                            android:textColor="#666666"
                            android:textSize="14sp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Ringkasan Periode Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Title with Icon -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/bar"
                                app:tint="#F9A825"
                                android:contentDescription="Ringkasan" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/RingkasanPeriode"
                                android:textColor="#000000"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginStart="8dp" />

                        </LinearLayout>

                        <!-- Stats Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:layout_marginBottom="16dp">

                            <!-- Kehadiran (Large Circle) -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <FrameLayout
                                    android:layout_width="80dp"
                                    android:layout_height="80dp">

                                    <ProgressBar
                                        android:id="@+id/progressKehadiran"
                                        style="?android:attr/progressBarStyleHorizontal"
                                        android:layout_width="80dp"
                                        android:layout_height="80dp"
                                        android:indeterminate="false"
                                        android:max="100"
                                        android:progress="88"
                                        android:progressDrawable="@drawable/circular_progress"
                                        android:rotation="-90" />

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <TextView
                                            android:id="@+id/tvCountKehadiran"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/PlaceholderNol"
                                            android:textColor="#4CAF50"
                                            android:textSize="20sp"
                                            android:textStyle="bold" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/Hadir"
                                            android:textColor="#666666"
                                            android:textSize="12sp" />

                                    </LinearLayout>

                                </FrameLayout>

                            </LinearLayout>

                            <!-- Izin -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    app:cardCornerRadius="8dp"
                                    app:cardElevation="0dp"
                                    app:cardBackgroundColor="#E3F2FD">

                                    <TextView
                                        android:id="@+id/tvCountIzin"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:gravity="center"
                                        android:text="@string/PlaceholderNol"
                                        android:textColor="#2196F3"
                                        android:textSize="20sp"
                                        android:textStyle="bold" />

                                </androidx.cardview.widget.CardView>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/Izin"
                                    android:textColor="#666666"
                                    android:textSize="12sp"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Stats Row 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:layout_marginBottom="16dp">

                            <!-- Sakit -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    app:cardCornerRadius="8dp"
                                    app:cardElevation="0dp"
                                    app:cardBackgroundColor="#FFF3E0">

                                    <TextView
                                        android:id="@+id/tvCountSakit"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:gravity="center"
                                        android:text="@string/PlaceholderNol"
                                        android:textColor="#FF9800"
                                        android:textSize="20sp"
                                        android:textStyle="bold" />

                                </androidx.cardview.widget.CardView>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/Sakit"
                                    android:textColor="#666666"
                                    android:textSize="12sp"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                            <!-- Alpha -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    app:cardCornerRadius="8dp"
                                    app:cardElevation="0dp"
                                    app:cardBackgroundColor="#FFEBEE">

                                    <TextView
                                        android:id="@+id/tvCountAlpha"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:gravity="center"
                                        android:text="@string/PlaceholderNol"
                                        android:textColor="#F44336"
                                        android:textSize="20sp"
                                        android:textStyle="bold" />

                                </androidx.cardview.widget.CardView>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/Alpha"
                                    android:textColor="#666666"
                                    android:textSize="12sp"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Unduh Laporan PDF Button - Removed as requested -->
                        
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Data Absensi Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvDataAbsensiTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/DataAbsensi0Entri"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExportExcel"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/ExportExcel"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        app:backgroundTint="#4CAF50"
                        app:cornerRadius="8dp" />

                </LinearLayout>

                <!-- Loading Progress Bar -->
                <ProgressBar
                    android:id="@+id/progressLoading"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <!-- Empty State Text -->
                <TextView
                    android:id="@+id/tvEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/TidakAdaDataAbsensiAlt"
                    android:textColor="#666666"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="24dp" />

                <!-- Horizontal Scrollable Table -->
                <HorizontalScrollView
                    android:id="@+id/tableHorizontalScrollView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fillViewport="true">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Table Header -->
                        <LinearLayout
                            android:id="@+id/tableHeader"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:orientation="horizontal"
                            android:background="#2196F3"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"
                                android:text="@string/Tanggal"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="8dp"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:text="@string/NIS"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="8dp"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="@string/Nama"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="8dp"
                                android:gravity="start" />

                            <TextView
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:text="@string/Kelas"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="4dp"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="70dp"
                                android:layout_height="wrap_content"
                                android:text="@string/Sholat"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="4dp"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:text="@string/Status"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="8dp"
                                android:gravity="center" />

                        </LinearLayout>

                        <!-- RecyclerView for Table Body -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerAbsensi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                    </LinearLayout>

                </HorizontalScrollView>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer (Sidebar) -->
    <include
        android:id="@+id/navigationView"
        layout="@layout/sidebar_laporan"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
