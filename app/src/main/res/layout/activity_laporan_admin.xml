<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        tools:context=".LaporanAdminActivity">

        <!-- Top Bar -->
        <View
            android:id="@+id/VectorAtasMenu"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:background="@color/blue_theme"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/topBarContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/iconMenu"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/menu"
                android:contentDescription="@string/Menu"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:tint="@android:color/white" />

            <ImageView
                android:id="@+id/logoSekolah"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/logo_smk"
                android:contentDescription="Logo SMKN 2"
                app:layout_constraintStart_toEndOf="@id/iconMenu"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/tvPageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/Laporan"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/logoSekolah"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@+id/textNamaSekolah"
                app:layout_constraintVertical_chainStyle="packed"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/textNamaSekolah"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="SMK Negeri 2 Singosari"
                android:textColor="#DBEAFE"
                android:textSize="12sp"
                android:ellipsize="end"
                android:maxLines="1"
                app:layout_constraintStart_toStartOf="@id/tvPageTitle"
                app:layout_constraintTop_toBottomOf="@id/tvPageTitle"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="8dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Scrollable Content -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/mainScrollView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintTop_toBottomOf="@id/topBarContent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/LaporanPresensi"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- ===== CHARTS SECTION ===== -->

                <!-- Chart: Kehadiran Hari Ini -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kehadiran Hari Ini"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!-- Donut progress -->
                            <FrameLayout
                                android:layout_width="100dp"
                                android:layout_height="100dp">

                                <ProgressBar
                                    android:id="@+id/progressDonutKehadiran"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="100dp"
                                    android:layout_height="100dp"
                                    android:indeterminate="false"
                                    android:max="100"
                                    android:progress="0"
                                    android:progressDrawable="@drawable/circular_progress"
                                    android:rotation="-90" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvDonutPersen"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0%"
                                        android:textColor="#000000"
                                        android:textSize="20sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Hadir"
                                        android:textColor="#666666"
                                        android:textSize="10sp" />

                                </LinearLayout>

                            </FrameLayout>

                            <!-- Legend -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp">

                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                                    <View android:layout_width="12dp" android:layout_height="12dp" android:background="#4CAF50" />
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Hadir" android:textColor="#666666" android:textSize="12sp" android:layout_marginStart="8dp" />
                                    <TextView android:id="@+id/tvLegendHadir" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#000000" android:textSize="12sp" android:textStyle="bold" />
                                </LinearLayout>

                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                                    <View android:layout_width="12dp" android:layout_height="12dp" android:background="#FF9800" />
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Izin" android:textColor="#666666" android:textSize="12sp" android:layout_marginStart="8dp" />
                                    <TextView android:id="@+id/tvLegendIzin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#000000" android:textSize="12sp" android:textStyle="bold" />
                                </LinearLayout>

                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                                    <View android:layout_width="12dp" android:layout_height="12dp" android:background="#2196F3" />
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sakit" android:textColor="#666666" android:textSize="12sp" android:layout_marginStart="8dp" />
                                    <TextView android:id="@+id/tvLegendSakit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#000000" android:textSize="12sp" android:textStyle="bold" />
                                </LinearLayout>

                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                    <View android:layout_width="12dp" android:layout_height="12dp" android:background="#F44336" />
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Alpha" android:textColor="#666666" android:textSize="12sp" android:layout_marginStart="8dp" />
                                    <TextView android:id="@+id/tvLegendAlpha" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#000000" android:textSize="12sp" android:textStyle="bold" />
                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Chart: Kehadiran per Jenis Sholat -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kehadiran per Jenis Sholat"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <!-- Dhuha -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="8dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                                <TextView android:layout_width="60dp" android:layout_height="wrap_content" android:text="Dhuha" android:textColor="#333333" android:textSize="12sp" />
                                <TextView android:id="@+id/tvBarDhuha" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#666666" android:textSize="11sp" android:layout_marginStart="4dp" />
                            </LinearLayout>
                            <ProgressBar android:id="@+id/progressBarDhuha" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="12dp" android:max="100" android:progress="0" android:progressDrawable="@drawable/progress_bar_green" android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Dzuhur -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="8dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                                <TextView android:layout_width="60dp" android:layout_height="wrap_content" android:text="Dzuhur" android:textColor="#333333" android:textSize="12sp" />
                                <TextView android:id="@+id/tvBarDzuhur" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#666666" android:textSize="11sp" android:layout_marginStart="4dp" />
                            </LinearLayout>
                            <ProgressBar android:id="@+id/progressBarDzuhur" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="12dp" android:max="100" android:progress="0" android:progressDrawable="@drawable/progress_bar_blue" android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Jumat -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                                <TextView android:layout_width="60dp" android:layout_height="wrap_content" android:text="Jumat" android:textColor="#333333" android:textSize="12sp" />
                                <TextView android:id="@+id/tvBarJumat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#666666" android:textSize="11sp" android:layout_marginStart="4dp" />
                            </LinearLayout>
                            <ProgressBar android:id="@+id/progressBarJumat" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="12dp" android:max="100" android:progress="0" android:progressDrawable="@drawable/progress_bar_orange" android:layout_marginTop="2dp" />
                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- ===== FILTER SECTION ===== -->

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/FilterLaporan"
                            android:textColor="#000000"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <!-- Search -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            app:boxCornerRadiusTopStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusBottomEnd="8dp"
                            app:startIconDrawable="@drawable/ic_search"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSearch"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Cari siswa..."
                                android:textSize="14sp"
                                android:inputType="text"
                                android:imeOptions="actionSearch"
                                android:maxLines="1" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Tanggal Awal -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/TanggalAwal"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvTanggalAwal"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_dropdown"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:text="@string/PlaceholderTanggalAwal"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp" />

                        <!-- Tanggal Akhir -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/TanggalAkhir"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvTanggalAkhir"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_dropdown"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:text="@string/PlaceholderTanggalAkhir"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp" />

                        <!-- Jenis Sholat -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jenis Sholat"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvFilterSholat"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_dropdown"
                            android:drawableEnd="@drawable/ic_chevron_right"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:text="Semua Sholat"
                            android:textColor="#666666"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp" />

                        <!-- Jurusan -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/Jurusan"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvFilterJurusan"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_dropdown"
                            android:drawableEnd="@drawable/ic_chevron_right"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:text="@string/SemuaJurusan"
                            android:textColor="#666666"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp" />

                        <!-- Kelas -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/Kelas"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvFilterKelas"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_dropdown"
                            android:drawableEnd="@drawable/ic_chevron_right"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:text="@string/SemuaKelas"
                            android:textColor="#666666"
                            android:textSize="14sp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- ===== DATA TABLE SECTION ===== -->

                <TextView
                    android:id="@+id/tvDataAbsensiTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/DataAbsensi0Entri"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDownloadLaporan"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Download"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        app:backgroundTint="@color/blue_theme"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/ic_download"
                        app:iconSize="16dp"
                        android:layout_marginEnd="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExportExcel"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Excel"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        app:backgroundTint="#4CAF50"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExportPdf"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="PDF"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        app:backgroundTint="#F44336"
                        app:cornerRadius="8dp" />

                </LinearLayout>

                <!-- Loading -->
                <ProgressBar
                    android:id="@+id/progressLoading"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <!-- Empty State -->
                <TextView
                    android:id="@+id/tvEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/TidakAdaDataAbsensiAlt"
                    android:textColor="#666666"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="24dp" />

                <!-- Data Table -->
                <HorizontalScrollView
                    android:id="@+id/tableHorizontalScrollView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fillViewport="true">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Table Header -->
                        <LinearLayout
                            android:id="@+id/tableHeader"
                            android:layout_width="wrap_content"
                            android:layout_height="42dp"
                            android:orientation="horizontal"
                            android:background="@color/blue_theme"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="40dp"
                                android:layout_height="wrap_content"
                                android:text="No"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="4dp"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:text="@string/Tanggal"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="4dp"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"
                                android:text="@string/NIS"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="4dp"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="110dp"
                                android:layout_height="wrap_content"
                                android:text="@string/Nama"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="4dp"
                                android:gravity="start" />

                            <TextView
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:text="@string/Kelas"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="4dp"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:text="@string/Sholat"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="4dp"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="70dp"
                                android:layout_height="wrap_content"
                                android:text="@string/Status"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="4dp"
                                android:gravity="center" />

                        </LinearLayout>

                        <!-- Table Rows -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerAbsensi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                    </LinearLayout>

                </HorizontalScrollView>

                <!-- Pagination Controls -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPrevPage"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Sebelumnya"
                        android:textColor="@color/blue_theme"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        app:strokeColor="@color/blue_theme"
                        app:rippleColor="#1A2886D6" />

                    <TextView
                        android:id="@+id/tvPageInfo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Halaman 1 dari 1"
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:gravity="center" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNextPage"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Selanjutnya"
                        android:textColor="@color/blue_theme"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        app:strokeColor="@color/blue_theme"
                        app:rippleColor="#1A2886D6" />

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Sidebar -->
    <include
        android:id="@+id/navigationView"
        layout="@layout/sidebar_admin"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
