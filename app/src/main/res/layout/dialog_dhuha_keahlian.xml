<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Jadwal Dhuha Keahlian"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hari"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="4dp"/>
    
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">
        <AutoCompleteTextView
            android:id="@+id/actvHari"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Pilih Hari"
            android:inputType="none"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Konsentrasi Keahlian 1"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="4dp"/>
    <TextView
        android:id="@+id/tvKeahlian1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Pilih Keahlian 1"
        android:background="@drawable/bg_input_rounded"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true"
        android:textColor="#333333"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Konsentrasi Keahlian 2"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="4dp"/>
    <TextView
        android:id="@+id/tvKeahlian2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Pilih Keahlian 2"
        android:background="@drawable/bg_input_rounded"
        android:padding="12dp"
        android:layout_marginBottom="24dp"
        android:clickable="true"
        android:focusable="true"
        android:textColor="#333333"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Batal"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="#666666"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Simpan"
            android:layout_marginStart="8dp"
            app:backgroundTint="@color/blue_theme"/>
    </LinearLayout>
</LinearLayout>
